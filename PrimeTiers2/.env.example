# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session secret (generate a long random string)
SESSION_SECRET=change-this-to-a-random-secret

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Server
PORT=3000
NODE_ENV=development

# Discord Bot (optional - for real-time online status)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Webhook secret (must match plugin config.yml)
WEBHOOK_SECRET=change-this-webhook-secret

# Bot Sync Settings
BOT_API_URL=http://localhost:20052
BOT_SYNC_INTERVAL_MS=300000
BOT_SYNC_ENABLED=true
